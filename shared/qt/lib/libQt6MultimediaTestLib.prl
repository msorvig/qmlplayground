QMAKE_PRL_TARGET = libQt6MultimediaTestLib.a
QMAKE_PRL_CONFIG = static
QMAKE_PRL_VERSION = 6.11.1
QMAKE_PRL_LIBS = $$[QT_INSTALL_LIBS]/libQt6Multimedia.so $$[QT_INSTALL_LIBS]/libQt6Gui.so $$[QT_INSTALL_LIBS]/libQt6Network.so -lopenal $$[QT_INSTALL_LIBS]/libQt6Test.so $$[QT_INSTALL_LIBS]/libQt6Core.so
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_LIBS]/libQt6Multimedia.so;$$[QT_INSTALL_LIBS]/libQt6Gui.so;$$[QT_INSTALL_LIBS]/libQt6Network.so;-lopenal;$$[QT_INSTALL_LIBS]/libQt6Test.so;$$[QT_INSTALL_LIBS]/libQt6Core.so
