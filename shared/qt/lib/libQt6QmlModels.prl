QMAKE_PRL_TARGET = libQt6QmlModels.so
QMAKE_PRL_CONFIG = shared
QMAKE_PRL_VERSION = 6.11.1
QMAKE_PRL_LIBS = $$[QT_INSTALL_LIBS]/libQt6Qml.so $$[QT_INSTALL_LIBS]/libQt6Network.so $$[QT_INSTALL_LIBS]/libQt6Core.so
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_LIBS]/libQt6Qml.so;$$[QT_INSTALL_LIBS]/libQt6Network.so;$$[QT_INSTALL_LIBS]/libQt6Core.so
