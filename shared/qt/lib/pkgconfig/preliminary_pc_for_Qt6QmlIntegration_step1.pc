prefix=/Users/msorvig/code/qmlplayground/qt/wasm-shared/qtbase
exec_prefix=${prefix}
bindir=${prefix}/bin
libexecdir=${prefix}/libexec
libdir=${prefix}/lib
includedir=${prefix}/include
$<$<BOOL:>:mkspecsdir=${prefix}/mkspecs>
$<1: >
Name: Qt6 QmlIntegration
Description: Qt QmlIntegration module
Version: 6.11.1
Libs: $<$<BOOL:loose_link_options-NOTFOUND>:$<JOIN:$<REMOVE_DUPLICATES:loose_link_options-NOTFOUND>, >> $<JOIN:$<REMOVE_DUPLICATES:>, >
Cflags: $<$<BOOL:${includedir}/QtQmlIntegration;${includedir}>:-I$<JOIN:$<REMOVE_DUPLICATES:${includedir}/QtQmlIntegration;${includedir}>, -I>> $<$<BOOL:QT_QMLINTEGRATION_LIB>:-D$<JOIN:$<REMOVE_DUPLICATES:QT_QMLINTEGRATION_LIB>, -D>>
Requires: $<JOIN:$<REMOVE_DUPLICATES:Qt6Core>, >
