QMAKE_PRL_TARGET = libQt6QmlDom.a
QMAKE_PRL_CONFIG = static
QMAKE_PRL_VERSION = 6.11.1
QMAKE_PRL_LIBS = $$[QT_INSTALL_LIBS]/libQt6QmlToolingSettings.a $$[QT_INSTALL_LIBS]/libQt6QmlCompiler.so $$[QT_INSTALL_LIBS]/libQt6Qml.so $$[QT_INSTALL_LIBS]/libQt6Network.so $$[QT_INSTALL_LIBS]/libQt6Core.so
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_LIBS]/libQt6QmlToolingSettings.a;$$[QT_INSTALL_LIBS]/libQt6QmlCompiler.so;$$[QT_INSTALL_LIBS]/libQt6Qml.so;$$[QT_INSTALL_LIBS]/libQt6Network.so;$$[QT_INSTALL_LIBS]/libQt6Core.so
